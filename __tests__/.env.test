# Test environment configuration
# Fixes connection issues and provides test-specific settings

NODE_ENV=test

# Redis Configuration (Fixed port)
REDIS_URL=redis://localhost:6379/15
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=15

# Database Configuration (Test database)
DATABASE_URL="postgresql://user:password@localhost:5432/chatwit_test"

# Disable external services in tests
DISABLE_EXTERNAL_APIS=true
MOCK_WHATSAPP_API=true
MOCK_DIALOGFLOW_API=true

# Test-specific settings
TEST_TIMEOUT=30000
JEST_TIMEOUT=30000

# Logging
LOG_LEVEL=error
DISABLE_CONSOLE_LOGS=true

# NextAuth (Mocked in tests)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=test-secret

# WhatsApp API (Mocked)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_API_TOKEN=test-token

# Disable real external connections
DISABLE_REDIS_CONNECTION=false
DISABLE_DATABASE_CONNECTION=false
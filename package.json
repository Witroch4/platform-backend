{
	"name": "socialwise",
	"version": "0.2.0",
	"private": true,
	"overrides": {
		"@auth/core": "0.37.4"
	},
	"scripts": {
		"db:push": "node scripts/db-push-dev.mjs",
		"db:prepare": "node scripts/db-prepare.js --mode=deploy",
		"db:reset:dev": "node scripts/db-prepare.js --mode=reset",
		"db:deploy": "node scripts/db-prepare.js --mode=deploy",
		"db:migrate": "prisma migrate dev",
		"db:generate": "prisma generate",
		"db:validate": "prisma validate",
		"db:seed": "prisma db seed",
		"db:seed-prices": "tsx scripts/seed-price-cards.ts",
		"fx-rates:init": "tsx scripts/init-fx-rate-system.ts",
		"fx-rates:test": "tsx scripts/test-fx-rates.ts",
		"db:full-reset": "tsx scripts/db-full-reset.ts",
		"test": "jest --detectOpenHandles --forceExit",
		"test:watch": "jest --watch --detectOpenHandles --forceExit",
		"test:coverage": "jest --coverage --detectOpenHandles --forceExit",
		"test:debug": "jest --detectOpenHandles --forceExit --verbose --no-cache",
		"test:unit": "jest --testPathPattern=__tests__/unit --detectOpenHandles --forceExit",
		"test:integration": "jest --testPathPattern=__tests__/integration --detectOpenHandles --forceExit",
		"test:e2e": "jest --testPathPattern=__tests__/e2e --detectOpenHandles --forceExit",
		"test:performance": "jest --testPathPattern=__tests__/performance --detectOpenHandles --forceExit",
		"test:comprehensive": "tsx scripts/run-comprehensive-tests.ts",
		"test:comprehensive:unit": "tsx scripts/run-comprehensive-tests.ts --skip-e2e --skip-integration",
		"test:comprehensive:verbose": "tsx scripts/run-comprehensive-tests.ts --verbose",
		"test:targeted": "tsx scripts/run-targeted-tests.ts",
		"test:targeted:unit": "jest __tests__/unit/parent-worker.test.ts --config=jest.config.targeted.js --verbose",
		"test:targeted:integration": "jest __tests__/integration/webhook-e2e.test.ts --config=jest.config.targeted.js --verbose",
		"test:targeted:frontend": "jest __tests__/frontend/ --config=jest.config.targeted.js --verbose",
		"test:targeted:coverage": "jest --config=jest.config.targeted.js --coverage --verbose",
		"test:setup-redis": "powershell -ExecutionPolicy Bypass -File scripts/setup-test-redis.ps1",
		"test:cleanup-redis": "powershell -ExecutionPolicy Bypass -File scripts/cleanup-test-redis.ps1",
		"test:integration:redis": "npm run test:setup-redis && npm run test:integration && npm run test:cleanup-redis",
		"build:workers": "tsc --project tsconfig.worker.json && tsc-alias --project tsconfig.worker.json",
		"build": "next build && npm run build:workers",
		"start:worker": "tsx --tsconfig tsconfig.worker.json worker/automacao.worker.ts",
		"worker": "tsx --tsconfig tsconfig.worker.json worker/webhook.worker.ts",
		"start:ai-worker": "tsx --tsconfig tsconfig.worker.json worker/ai-integration.worker.ts",
		"start:webhook:prod": "node dist/worker/webhook.worker.js",
		"start:automacao:prod": "node dist/worker/automacao.worker.js",
		"start:ai-worker:prod": "node dist/worker/ai-integration.worker.js",
		"server": "node server.js",
		"rollout": "tsx scripts/rollout-management.ts",
		"init-monitoring": "tsx scripts/init-monitoring.ts",
		"test-redis": "tsx scripts/test-redis.ts",
		"flash-intent": "tsx scripts/manage-flash-intent.ts",
		"setup-flash-intent-dev": "tsx scripts/setup-flash-intent-dev.ts",
		"dev": "node server.js",
		"dev:turbo": "next dev --turbo",
		"dev:polling": "next dev --turbo",
		"devv": "next dev",
		"start": "next start",
		"db:clear": "prisma migrate reset -f",
		"db:studio": "prisma studio",
		"wit": "node ./clonedb.js",
		"postinstall": "prisma generate",
		"lint": "npx @biomejs/biome lint ./",
		"lint-apply": "npx @biomejs/biome lint ./ --apply",
		"format": "npx @biomejs/biome format ./",
		"format-apply": "npx @biomejs/biome format ./ --write",
		"check": "npx @biomejs/biome check ./",
		"check-apply": "npx @biomejs/biome check ./ --apply",
		"backup": "tsx scripts/backup-database.ts backup",
		"backup:simple": "tsx scripts/backup-simple.ts",
		"backup:json": "tsx scripts/backup-database.ts backup --format json",
		"backup:sql": "tsx scripts/backup-database.ts backup --format sql",
		"restore": "tsx scripts/restore-database.ts",
		"restore:dry-run": "tsx scripts/restore-database.ts --dry-run",
		"restore:help": "tsx scripts/restore-database.ts help",
		"backup:list": "tsx scripts/backup-utils.ts list",
		"backup:info": "tsx scripts/backup-utils.ts info",
		"backup:help": "tsx scripts/backup-database.ts help",
		"backup:schedule": "tsx scripts/backup-scheduler.ts start",
		"backup:schedule:run": "tsx scripts/backup-scheduler.ts run",
		"backup:schedule:config": "tsx scripts/backup-scheduler.ts config",
		"backup:schedule:enable": "tsx scripts/backup-scheduler.ts enable",
		"backup:schedule:disable": "tsx scripts/backup-scheduler.ts disable"
	},

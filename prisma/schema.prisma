  isDefault    Boolean         @default(false)
  abTestWeight Float           @default(1.0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  createdById  String
  auditLogs    LlmAudit[]
  metrics      PromptMetrics[]
  assistant    AiAssistant     @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  createdBy    User            @relation(fields: [createdById], references: [id])

  @@unique([assistantId, name, version])
  @@index([assistantId, isActive])
  @@index([promptType, isActive])
}

model PromptMetrics {
  id              String        @id @default(cuid())
  promptVersionId String
  date            DateTime      @default(now())
  totalUsage      Int           @default(0)
  successRate     Float         @default(0)
  averageLatency  Float         @default(0)
  averageScore    Float         @default(0)
  tokenUsage      Int           @default(0)
  errorRate       Float         @default(0)
  promptVersion   PromptVersion @relation(fields: [promptVersionId], references: [id], onDelete: Cascade)

  @@unique([promptVersionId, date])
  @@index([date])
}

model PromptABTest {
  id              String      @id @default(cuid())
  name            String
  description     String?
  assistantId     String
  promptVersions  String[]
  trafficSplit    Json
  isActive        Boolean     @default(false)

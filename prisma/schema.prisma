// Modelo para mapeamento de intents do Dialogflow para templates
model MtfDiamanteIntentMapping {
  id       String            @id @default(cuid())
  configId String
  config   MtfDiamanteConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  // Mapeamento de Intent do Dialogflow para Template
  intentName   String // Nome da intenção do Dialogflow
  templateName String // Nome do template do WhatsApp

  // Parâmetros opcionais
  parameters Json? // Parâmetros específicos para o template

  // Status
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([configId, intentName])
  @@index([configId])
  @@index([intentName])
}

// Modelo para controle de disparos em massa do MTF Diamante
model DisparoMtfDiamante {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Informações do template e lead
  templateId   String // ID do template WhatsApp
  templateName String // Nome do template
  leadId       String // ID do lead
  leadNome     String? // Nome do lead
  leadTelefone String? // Telefone do lead

  // Status do disparo
  status String @default("PENDING") // PENDING, SENT, FAILED, SCHEDULED

  // Controle de agendamento
  scheduledAt DateTime? // Quando deve ser enviado
  sentAt      DateTime? // Quando foi enviado

  // Parâmetros e configuração
  parameters Json? // Parâmetros específicos para o template

  // Controle de erro
  errorMessage String? // Mensagem de erro se falhou

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
  @@index([leadId])
}

// Modelo para armazenar modelos de recurso
model ModeloRecurso {
  id       String  @id @default(cuid())
  texto    String  @db.Text // Texto do modelo de recurso
  isGlobal Boolean @default(false) // Se é um modelo global

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isGlobal])
}

// Tabelas para integração WhatsApp/Dialogflow
model LoteOab {
  id           String   @id @default(cuid())
  nome         String
  valor        Decimal  @db.Decimal(10, 2)
  valorAnalise Decimal  @db.Decimal(10, 2)
  chavePix     String
  dataInicio   DateTime
  dataFim      DateTime
  ativo        Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // MUDANÇA: Relacionamento agora é com UsuarioChatwit
  usuarioChatwitId String
  usuarioChatwit   UsuarioChatwit @relation(fields: [usuarioChatwitId], references: [id], onDelete: Cascade)
  leads            LeadOab[]

  @@map("lote_oab")
}

// REMOVIDO: model TemplateWhatsappOab - consolidado em WhatsAppTemplate

model MensagemInterativa {
  id             String   @id @default(cuid())
  nome           String? // <-- ADICIONADO
  tipo           String
  texto          String   @db.Text
  headerTipo     String?
  headerConteudo String?  @db.Text
  rodape         String?
  ativo          Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  usuarioChatwitId String
  usuarioChatwit   UsuarioChatwit  @relation(fields: [usuarioChatwitId], references: [id], onDelete: Cascade)
  botoes           BotaoMensagem[]

  // --- RELACIONAMENTO ADICIONADO ---
  caixaEntradaId String?
  caixaEntrada   CaixaEntrada? @relation(fields: [caixaEntradaId], references: [id], onDelete: SetNull)

  // Relação com mapeamentos de intenção
  mapeamentos MapeamentoIntencao[]

  @@map("mensagem_interativa")
}

model BotaoMensagem {
  id        String   @id @default(cuid())
  titulo    String
  ordem     Int
  createdAt DateTime @default(now())

  // Relacionamentos
  mensagemId String
  mensagem   MensagemInterativa @relation(fields: [mensagemId], references: [id], onDelete: Cascade)

  @@map("botao_mensagem")
}

model CaixaEntrada {
  id               String   @id @default(cuid())
  nome             String
  chatwitAccountId String
  inboxId          String
  inboxName        String
  channelType      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  usuarioChatwitId String
  usuarioChatwit   UsuarioChatwit     @relation(fields: [usuarioChatwitId], references: [id], onDelete: Cascade)
  agentes          AgenteDialogflow[]

  // --- NOVOS RELACIONAMENTOS ---
  configuracaoWhatsApp WhatsAppConfig?      @relation(name: "ConfigCaixa")
  templates            WhatsAppTemplate[]
  mensagensInterativas MensagemInterativa[]
  mapeamentosIntencao  MapeamentoIntencao[]
  
  // Enhanced Interactive Messages
  interactiveMessages  InteractiveMessage[]
  
  // Unified Template System
  unifiedTemplates     Template[]

  // Relacionamento para o fallback
  fallbackParaCaixaId String?
  fallbackParaCaixa   CaixaEntrada?  @relation("FallbackCaixa", fields: [fallbackParaCaixaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fallbackDeCaixas    CaixaEntrada[] @relation("FallbackCaixa")

  @@unique([usuarioChatwitId, inboxId])
  @@map("caixa_entrada")
}

// Modelo para agentes Dialogflow
model AgenteDialogflow {
  id          String   @id @default(cuid())
  nome        String
  projectId   String // ID do projeto Dialogflow
  credentials String   @db.Text // JSON das credenciais
  region      String   @default("global")
  hookId      String? // ID do hook na API do Chatwit
  ativo       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // MUDANÇA: Relacionamento agora é com UsuarioChatwit
  usuarioChatwitId String
  usuarioChatwit   UsuarioChatwit @relation(fields: [usuarioChatwitId], references: [id], onDelete: Cascade)
  caixaId          String
  caixa            CaixaEntrada   @relation(fields: [caixaId], references: [id], onDelete: Cascade)
  //@@unique([caixaId, ativo]) // Apenas um agente ativo por caixa

  @@map("agente_dialogflow")
}



model LeadOab {
  id        String   @id @default(cuid())
  nome      String
  telefone  String
  payload   String?  @db.Text // JSON do payload do Chatwit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // MUDANÇA: Relacionamento agora é com UsuarioChatwit
  usuarioChatwitId String
  usuarioChatwit   UsuarioChatwit @relation(fields: [usuarioChatwitId], references: [id], onDelete: Cascade)
  loteId           String
  lote             LoteOab        @relation(fields: [loteId], references: [id], onDelete: Cascade)

  @@map("lead_oab")
}

model MapeamentoIntencao {
  id         String @id @default(cuid())
  intentName String

  caixaEntradaId String
  caixaEntrada   CaixaEntrada @relation(fields: [caixaEntradaId], references: [id], onDelete: Cascade)

  // Legacy relationships (to be deprecated)
  templateId String?
  template   WhatsAppTemplate? @relation(fields: [templateId], references: [templateId], onDelete: SetNull)

  mensagemInterativaId String?
  mensagemInterativa   MensagemInterativa? @relation(fields: [mensagemInterativaId], references: [id], onDelete: SetNull)

  // New unified template relationship
  unifiedTemplateId String?
  unifiedTemplate   Template? @relation("TemplateMappings", fields: [unifiedTemplateId], references: [id], onDelete: SetNull)

  // Enhanced Interactive Message relationship
  interactiveMessageId String?
  interactiveMessage   InteractiveMessage? @relation("InteractiveMessageMappings", fields: [interactiveMessageId], references: [id], onDelete: SetNull)

  @@unique([intentName, caixaEntradaId])
}

// Template Library System Models
model TemplateLibrary {
  id                   String   @id @default(cuid())
  name                 String
  description          String?
  type                 String   // 'template' | 'interactive_message'
  scope                String   // 'global' | 'account_specific'
  isApprovalRequired   Boolean  @default(true)
  isActive             Boolean  @default(true)
  totalUsageCount      Int      @default(0)
  
  // Template content stored as JSON
  content              Json
  
  // Metadata
  category             String?
  language             String   @default("pt_BR")
  tags                 String[] // Array of tags for categorization
  
  // Relationships
  createdById          String
  createdBy            User     @relation("CreatedTemplates", fields: [createdById], references: [id], onDelete: Cascade)
  
  // Approval requests
  approvalRequests     TemplateApprovalRequest[]
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  @@index([createdById])
  @@index([type])
  @@index([scope])
  @@index([isActive])
  @@index([category])
  @@map("template_library")
}

model TemplateApprovalRequest {
  id                   String   @id @default(cuid())
  status               String   @default("pending") // 'pending' | 'approved' | 'rejected'
  requestMessage       String?  // Optional message from requester
  responseMessage      String?  // Optional response from approver
  
  // Custom variables for this specific request
  customVariables      Json?    // User-specific variable values
  
  // Relationships
  templateLibraryId    String
  templateLibrary      TemplateLibrary @relation(fields: [templateLibraryId], references: [id], onDelete: Cascade)
  
  // New unified template relationship
  unifiedTemplateId    String?
  unifiedTemplate      Template? @relation("TemplateApprovals", fields: [unifiedTemplateId], references: [id], onDelete: Cascade)
  
  requestedById        String
  requestedBy          User     @relation("RequestedApprovals", fields: [requestedById], references: [id], onDelete: Cascade)
  
  processedById        String?
  processedBy          User?    @relation("ProcessedApprovals", fields: [processedById], references: [id], onDelete: SetNull)
  
  requestedAt          DateTime @default(now())
  processedAt          DateTime?
  
  @@index([templateLibraryId])
  @@index([requestedById])
  @@index([status])
  @@map("template_approval_request")
}
// Webhook processing models for MTF Diamante
model WebhookMessage {
  id                  String   @id @default(cuid())
  whatsappMessageId   String   // Message ID from WhatsApp (wamid)
  conversationId      String   // Conversation ID from WhatsApp
  contactPhone        String   // Contact phone number
  messageContent      String   @db.Text // Message content
  messageType         String   @default("text") // text, interactive, template, etc.
  whatsappApiKey      String   // WhatsApp API key extracted from payload
  inboxId             String   // Inbox ID from Chatwit
  rawPayload          Json     // Complete raw payload from Dialogflow
  processed           Boolean  @default(false) // Processing status
  timestamp           DateTime @default(now()) // Message timestamp
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([whatsappMessageId])
  @@index([conversationId])
  @@index([contactPhone])
  @@index([inboxId])
  @@index([timestamp])
  @@map("webhook_message")
}

model ConversationThread {
  id                      String   @id @default(cuid())
  whatsappConversationId  String   @unique // WhatsApp conversation ID
  contactPhone            String   // Contact phone number
  lastMessageAt           DateTime // Timestamp of last message
  status                  String   @default("active") // active, closed
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([contactPhone])
  @@index([lastMessageAt])
  @@map("conversation_thread")
}

model DialogflowIntent {
  id           String   @id @default(cuid())
  intentName   String   // Name of the Dialogflow intent
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Enhanced Interactive Message model for all WhatsApp interactive message types
model InteractiveMessage {
  id          String   @id @default(cuid())
  caixaId     String   // Reference to CaixaEntrada
  name        String   // User-friendly name for the message
  type        String   // Message type: 'cta_url', 'flow', 'list', 'button', 'location', 'location_request', 'reaction', 'sticker'
  
  // Header fields
  headerType     String?  // 'text', 'image', 'video', 'document'
  headerContent  String?  @db.Text // Text content or media URL/ID
  
  // Body (required for most message types)
  bodyText       String   @db.Text // Main message body text
  
  // Footer (optional)
  footerText     String?  // Footer text (max 60 characters)
  
  // Action-specific fields stored as JSON for flexibility
  actionData     Json?    // Contains buttons, sections, flow parameters, etc.
  
  // Location-specific fields (for location messages)
  latitude       Float?   // Location latitude
  longitude      Float?   // Location longitude
  locationName   String?  // Location name
  locationAddress String? // Location address
  
  // Reaction-specific fields
  reactionEmoji  String?  // Emoji for reaction messages
  targetMessageId String? // WhatsApp message ID to react to
  
  // Sticker-specific fields
  stickerMediaId String?  // Media ID for sticker
  stickerUrl     String?  // URL for sticker (not recommended by WhatsApp)
  
  // Status and metadata
  isActive       Boolean  @default(true)
  usageCount     Int      @default(0) // Track how many times this message was sent
  
  createdById String   // User who created the message
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  caixa       CaixaEntrada @relation(fields: [caixaId], references: [id], onDelete: Cascade)
  createdBy   User         @relation(fields: [createdById], references: [id])
  
  // Relation with intent mappings
  mapeamentos MapeamentoIntencao[] @relation("InteractiveMessageMappings")

  @@index([caixaId])
  @@index([type])
  @@index([createdById])
  @@index([isActive])
}
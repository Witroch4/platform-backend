generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String                    @id @default(cuid())
  name                        String?
  email                       String                    @unique
  emailVerified               DateTime?
  image                       String?
  role                        UserRole                  @default(DEFAULT)
  password                    String?
  isTwoFactorAuthEnabled      Boolean                   @default(false)
  twoFactorAuthVerified       DateTime?
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt
  isNew                       Boolean                   @default(true)
  mtfDiamanteSeedExecuted     Boolean                   @default(false)
  mtfVariaveisPopuladas       Boolean                   @default(false)
  turboModeEnabled            Boolean                   @default(false)
  accounts                    Account[]
  agendamentos                Agendamento[]
  aiAgentBlueprints           AiAgentBlueprint[]
  aiAgentConfig               AiAgentConfig?
  aiAssistants                AiAssistant[]
  aiDocuments                 AiDocument[]
  aiFaqs                      AiFaq[]
  apiKeys                     ApiKey[]
  auditLogs                   AuditLog[]
  automacoes                  Automacao[]
  chatSessions                ChatSession[]
  disparosMtfDiamante         DisparoMtfDiamante[]
  generatedImages             GeneratedImage[]
  iframeAuthorizedDomains     IframeAuthorizedDomain[]
  inboxConfigHistory          InboxConfigHistory[]
  intents                     Intent[]
  Lead                        Lead[]
  mtfDiamanteConfig           MtfDiamanteConfig?
  notifications               Notification[]
  pastas                      Pasta[]
  abTests                     PromptABTest[]
  promptVersions              PromptVersion[]
  subscriptions               Subscription[]
  templates                   Template[]
  processedApprovalRequests   TemplateApprovalRequest[] @relation("ProcessedBy")
  approvalRequests            TemplateApprovalRequest[] @relation("ApprovalRequests")
  createdFeatureFlagOverrides UserFeatureFlagOverride[] @relation("CreatedUserFeatureFlagOverrides")
  featureFlagOverrides        UserFeatureFlagOverride[]
  usuarioChatwit              UsuarioChatwit?
}

model InboxConfigHistory {
  id             String       @id @default(cuid())
  inboxId        String
  userId         String
  changeType     String
  previousConfig Json?
  newConfig      Json
  description    String?
  createdAt      DateTime     @default(now())
  inbox          ChatwitInbox @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@index([inboxId, createdAt(sort: Desc)])
  @@index([userId])
}

model Account {
  id                String        @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  igUserId          String?
  igUsername        String?
  isMain            Boolean       @default(false)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  agendamentos      Agendamento[]
  automacoes        Automacao[]
  chats             Chat[]
  leads             Lead[]

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Lead {
  id               String                @id @default(cuid())
  name             String?
  email            String?
  phone            String?
  avatarUrl        String?
  source           LeadSource
  sourceIdentifier String
  tags             String[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  userId           String?
  accountId        String?
  chats            Chat[]
  disparos         DisparoMtfDiamante[]
  account          Account?              @relation(fields: [accountId], references: [id])
  user             User?                 @relation(fields: [userId], references: [id])
  automacoes       LeadAutomacao[]
  instagramProfile LeadInstagramProfile?
  oabData          LeadOabData?

  @@unique([source, sourceIdentifier, accountId])
  @@index([userId, accountId, email, phone])
  @@index([tags])
}

model LeadInstagramProfile {
  id            String    @id @default(cuid())
  leadId        String    @unique
  isFollower    Boolean   @default(false)
  lastMessageAt DateTime?
  isOnline      Boolean   @default(false)
  lead          Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadOabData {
  id                     String                 @id @default(cuid())
  leadId                 String                 @unique
  nomeReal               String?
  concluido              Boolean                @default(false)
  anotacoes              String?
  pdfUnificado           String?
  imagensConvertidas     String?
  leadUrl                String?
  fezRecurso             Boolean                @default(false)
  datasRecurso           String?
  provaManuscrita        Json?
  manuscritoProcessado   Boolean                @default(false)
  aguardandoManuscrito   Boolean                @default(false)
  espelhoCorrecao        String?
  textoDOEspelho         Json?
  espelhoProcessado      Boolean                @default(false)
  aguardandoEspelho      Boolean                @default(false)
  analiseUrl             String?
  argumentacaoUrl        String?
  analiseProcessada      Boolean                @default(false)
  aguardandoAnalise      Boolean                @default(false)
  analisePreliminar      Json?
  analiseValidada        Boolean                @default(false)
  consultoriaFase2       Boolean                @default(false)
  recursoPreliminar      Json?
  recursoValidado        Boolean                @default(false)
  recursoUrl             String?
  recursoArgumentacaoUrl String?
  aguardandoRecurso      Boolean                @default(false)
  seccional              String?
  areaJuridica           String?
  notaFinal              Float?
  situacao               String?
  inscricao              String?
  examesParticipados     Json?
  especialidade          String? // Área jurídica (ex: "DIREITO DO TRABALHO", "TRABALHO" - aceita qualquer string)
  espelhoPadraoId        String? // ID do espelho padrão selecionado (OabRubric ou EspelhoPadrao)
  usuarioChatwitId       String
  espelhoBibliotecaId    String?
  arquivos               ArquivoLeadOab[]
  espelhoBiblioteca      EspelhoBiblioteca?     @relation(fields: [espelhoBibliotecaId], references: [id])
  lead                   Lead                   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  usuarioChatwit         UsuarioChatwit         @relation(fields: [usuarioChatwitId], references: [id], onDelete: Cascade)
  submissions            OabSubmission[]

  @@index([usuarioChatwitId, espelhoBibliotecaId])
}

model ArquivoLeadOab {
  id              String      @id @default(cuid())
  leadOabDataId   String
  fileType        String
  dataUrl         String
  pdfConvertido   String?
  chatwitFileId   Int?        @unique // ID único do arquivo no Chatwit para deduplicação
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  leadOabData     LeadOabData @relation(fields: [leadOabDataId], references: [id], onDelete: Cascade)

  @@index([leadOabDataId])
}

model OabRubric {
  id          String             @id @default(cuid())
  code        String?
  exam        String?
  area        String?
  version     String?
  meta        Json?
  schema      Json
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  evaluations OabEvaluationRun[]
}

model OabSubmission {
  id            String             @id @default(cuid())
  leadOabDataId String?
  alunoNome     String?
  sourcePdfUrl  String?
  sourceImages  Json?
  rawExtracted  Json
  chunkConfig   Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  evaluations   OabEvaluationRun[]
  leadOabData   LeadOabData?       @relation(fields: [leadOabDataId], references: [id])

  @@index([leadOabDataId])
}

model OabEvaluationRun {
  id           String        @id @default(cuid())
  submissionId String
  rubricId     String
  status       String        @default("PENDING")
  strategy     Json?
  scores       Json?
  evidences    Json?
  report       Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  rubric       OabRubric     @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  submission   OabSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([rubricId])
}

model UsuarioChatwit {
  id                         String                @id @default(cuid())
  appUserId                  String                @unique
  name                       String
  availableName              String?
  accountName                String
  channel                    String
  chatwitAccessToken         String?               @unique
  chatwitAccountId           String
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt
  agentesDialogflow          AgenteDialogflow[]
  inboxes                    ChatwitInbox[]
  espelhosBiblioteca         EspelhoBiblioteca[]
  espelhosPadrao             EspelhoPadrao[]
  leadsOabData               LeadOabData[]
  appUser                    User                  @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  configuracaoGlobalWhatsApp WhatsAppGlobalConfig?
}

model ApiKey {
  id          String    @id @default(cuid())
  label       String?
  ownerId     String
  tokenHash   String    @unique
  tokenPrefix String    @db.VarChar(16)
  tokenSuffix String    @db.VarChar(16)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, active])
}

model WhatsAppGlobalConfig {
  id                        String         @id @default(cuid())
  usuarioChatwitId          String         @unique
  whatsappApiKey            String
  phoneNumberId             String
  whatsappBusinessAccountId String
  graphApiBaseUrl           String         @default("https://graph.facebook.com/v22.0")
  updatedAt                 DateTime       @updatedAt
  usuarioChatwit            UsuarioChatwit @relation(fields: [usuarioChatwitId], references: [id], onDelete: Cascade)
}

model ChatwitInbox {
  id                         String               @id @default(cuid())
  nome                       String
  inboxId                    String
  channelType                String
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  usuarioChatwitId           String
  whatsappApiKey             String?
  phoneNumberId              String?
  whatsappBusinessAccountId  String?
  fallbackParaInboxId        String?
  socialwiseInheritFromAgent Boolean?             @default(true)
  socialwiseReasoningEffort  String?
  socialwiseVerbosity        String?
  socialwiseTemperature      Float?
  socialwiseTempSchema       Float?
  socialwiseWarmupDeadlineMs Int?
  socialwiseHardDeadlineMs   Int?
  socialwiseSoftDeadlineMs   Int?
  socialwiseShortTitleLLM    Boolean?
  socialwiseToolChoice       String?
  agentes                    AgenteDialogflow[]
  aiAssistantLinks           AiAssistantInbox[]
  fallbackParaInbox          ChatwitInbox?        @relation("FallbackInbox", fields: [fallbackParaInboxId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fallbackDeInboxes          ChatwitInbox[]       @relation("FallbackInbox")
  usuarioChatwit             UsuarioChatwit       @relation(fields: [usuarioChatwitId], references: [id], onDelete: Cascade)
  configHistory              InboxConfigHistory[]
  flowCanvas                 InboxFlowCanvas?
  flows                      Flow[]
  mapeamentosBotoes          MapeamentoBotao[]
  mapeamentosIntencao        MapeamentoIntencao[]
  templates                  Template[]

  @@unique([usuarioChatwitId, inboxId])
}

model Template {
  id                   String                    @id @default(cuid())
  name                 String
  description          String?
  type                 TemplateType
  scope                TemplateScope             @default(PRIVATE)
  status               TemplateStatus            @default(APPROVED)
  language             String                    @default("pt_BR")
  tags                 String[]
  isActive             Boolean                   @default(true)
  usageCount           Int                       @default(0)
  simpleReplyText      String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  createdById          String
  inboxId              String?
  intents              Intent[]
  interactiveContent   InteractiveContent?
  mapeamentos          MapeamentoIntencao[]
  createdBy            User                      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  inbox                ChatwitInbox?             @relation(fields: [inboxId], references: [id])
  approvalRequests     TemplateApprovalRequest[]
  whatsappOfficialInfo WhatsAppOfficialInfo?

  @@index([createdById, inboxId, type, scope, status, isActive])
}

model TemplateApprovalRequest {
  id              String    @id @default(cuid())
  templateId      String
  status          String    @default("pending")
  requestMessage  String?
  responseMessage String?
  requestedById   String
  processedById   String?
  requestedAt     DateTime  @default(now())
  processedAt     DateTime?
  processedBy     User?     @relation("ProcessedBy", fields: [processedById], references: [id])
  requestedBy     User      @relation("ApprovalRequests", fields: [requestedById], references: [id], onDelete: Cascade)
  template        Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, requestedById, status])
}

model MapeamentoBotao {
  id            String       @id @default(cuid())
  buttonId      String       @unique
  actionType    ActionType
  actionPayload Json
  description   String?
  inboxId       String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  inbox         ChatwitInbox @relation(fields: [inboxId], references: [id], onDelete: Cascade)

  @@index([inboxId])
}

model InboxFlowCanvas {
  id        String       @id @default(cuid())
  inboxId   String       @unique
  canvas    Json // { nodes: FlowNode[], edges: FlowEdge[], viewport: { x, y, zoom } }
  version   Int          @default(1)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  inbox     ChatwitInbox @relation(fields: [inboxId], references: [id], onDelete: Cascade)
}

model InteractiveContent {
  id                    String                 @id @default(cuid())
  templateId            String                 @unique
  bodyId                String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  interactiveType       String                 @default("button")
  genericPayload        Json?
  actionCtaUrl          ActionCtaUrl?
  actionFlow            ActionFlow?
  actionList            ActionList?
  actionLocationRequest ActionLocationRequest?
  actionReplyButton     ActionReplyButton?
  footer                Footer?
  header                Header?
  body                  Body                   @relation(fields: [bodyId], references: [id])
  template              Template               @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model WhatsAppOfficialInfo {
  id             String   @id @default(cuid())
  templateId     String   @unique
  metaTemplateId String
  status         String
  category       String
  qualityScore   String?
  components     Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  template       Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([metaTemplateId, status])
}

model Header {
  id                   String             @id @default(cuid())
  type                 String
  content              String
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)
}

model Body {
  id                  String               @id @default(cuid())
  text                String
  interactiveContents InteractiveContent[]
}

model Footer {
  id                   String             @id @default(cuid())
  text                 String
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)
}

model ActionCtaUrl {
  id                   String             @id @default(cuid())
  displayText          String
  url                  String
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)
}

model ActionReplyButton {
  id                   String             @id @default(cuid())
  buttons              Json
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)
}

model ActionList {
  id                   String             @id @default(cuid())
  buttonText           String
  sections             Json
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)
}

model ActionFlow {
  id                   String             @id @default(cuid())
  flowId               String
  flowCta              String
  flowMode             String             @default("published")
  flowData             Json?
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)
}

model ActionLocationRequest {
  id                   String             @id @default(cuid())
  requestText          String
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)
}

model AgenteDialogflow {
  id               String         @id @default(cuid())
  nome             String
  projectId        String
  credentials      String
  region           String         @default("global")
  hookId           String?
  ativo            Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  usuarioChatwitId String
  inboxId          String
  inbox            ChatwitInbox   @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  usuarioChatwit   UsuarioChatwit @relation(fields: [usuarioChatwitId], references: [id], onDelete: Cascade)
}

model MapeamentoIntencao {
  id              String       @id @default(cuid())
  intentName      String
  inboxId         String
  templateId      String?      // Opcional: pode ser template OU flow
  flowId          String?      // Opcional: ID do Flow associado
  customVariables Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  inbox           ChatwitInbox @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  template        Template?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  flow            Flow?        @relation(fields: [flowId], references: [id], onDelete: SetNull)

  @@unique([intentName, inboxId])
  @@index([flowId])
}

model Automacao {
  id               String          @id @default(cuid())
  userId           String
  folderId         String?
  accountId        String
  selectedMediaId  String?
  anyMediaSelected Boolean         @default(false)
  anyword          Boolean         @default(true)
  palavrasChave    String?
  fraseBoasVindas  String?
  publicReply      String?
  buttonPayload    String          @unique
  live             Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  account          Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  folder           Pasta?          @relation(fields: [folderId], references: [id])
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadsAutomacao   LeadAutomacao[]

  @@index([userId, accountId])
}

model LeadAutomacao {
  id              String    @id @default(cuid())
  leadId          String
  automacaoId     String
  linkSent        Boolean   @default(false)
  waitingForEmail Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  automacao       Automacao @relation(fields: [automacaoId], references: [id], onDelete: Cascade)
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, automacaoId])
}

model MtfDiamanteConfig {
  id        String                @id @default(cuid())
  userId    String                @unique
  isActive  Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  variaveis MtfDiamanteVariavel[]
}

model MtfDiamanteVariavel {
  id        String            @id @default(cuid())
  configId  String
  chave     String
  valor     Json
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  config    MtfDiamanteConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, chave])
}

model DisparoMtfDiamante {
  id           String    @id @default(cuid())
  userId       String
  templateName String
  leadId       String
  status       String    @default("PENDING")
  scheduledAt  DateTime?
  sentAt       DateTime?
  parameters   Json?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, leadId])
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model ResetPasswordToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model Pasta {
  id         String      @id @default(cuid())
  name       String
  userId     String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  automacoes Automacao[]
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  stripeSubscriptionId String             @unique
  stripeCustomerId     String
  status               SubscriptionStatus
  startDate            DateTime
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Agendamento {
  id                             String   @id @default(cuid())
  userId                         String
  accountId                      String
  data                           DateTime
  descricao                      String?
  facebook                       Boolean  @default(false)
  instagram                      Boolean  @default(false)
  linkedin                       Boolean  @default(false)
  x                              Boolean  @default(false)
  stories                        Boolean  @default(false)
  reels                          Boolean  @default(false)
  postNormal                     Boolean  @default(false)
  diario                         Boolean  @default(false)
  semanal                        Boolean  @default(false)
  randomizar                     Boolean  @default(false)
  tratarComoUnicoPost            Boolean  @default(false)
  tratarComoPostagensIndividuais Boolean  @default(false)
  concluidoFB                    Boolean  @default(false)
  concluidoIG                    Boolean  @default(false)
  concluidoLK                    Boolean  @default(false)
  concluidoX                     Boolean  @default(false)
  createdAt                      DateTime @default(now())
  account                        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user                           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  midias                         Midia[]
}

model Midia {
  id            String      @id @default(cuid())
  agendamentoId String
  url           String
  mime_type     String
  thumbnail_url String?
  contador      Int         @default(0)
  createdAt     DateTime    @default(now())
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)

  @@index([agendamentoId])
}

model Chat {
  id        String    @id @default(cuid())
  leadId    String
  accountId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([leadId, accountId])
}

model Message {
  id         String   @id @default(cuid())
  chatId     String
  content    String
  isFromLead Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
}

model ChatSession {
  id              String           @id @default(cuid())
  userId          String
  title           String           @default("Nova conversa")
  model           String           @default("chatgpt-4o-latest")
  summary         String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  files           ChatFile[]
  messages        ChatMessage[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedImages GeneratedImage[]

  @@index([userId])
}

model ChatMessage {
  id              String      @id @default(cuid())
  sessionId       String

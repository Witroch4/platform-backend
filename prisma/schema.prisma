generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String                    @id @default(cuid())
  name                      String?
  email                     String                    @unique
  emailVerified             DateTime?
  image                     String?
  role                      UserRole                  @default(DEFAULT)
  password                  String?
  isTwoFactorAuthEnabled    Boolean                   @default(false)
  twoFactorAuthVerified     DateTime?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  isNew                     Boolean                   @default(true)
  mtfDiamanteSeedExecuted   Boolean                   @default(false)
  mtfVariaveisPopuladas     Boolean                   @default(false)
  accounts                  Account[]
  agendamentos              Agendamento[]
  automacoes                Automacao[]
  chatSessions              ChatSession[]
  disparosMtfDiamante       DisparoMtfDiamante[]
  generatedImages           GeneratedImage[]
  Lead                      Lead[]
  mtfDiamanteConfig         MtfDiamanteConfig?
  notifications             Notification[]
  pastas                    Pasta[]
  subscriptions             Subscription[]
  templates                 Template[]
  processedApprovalRequests TemplateApprovalRequest[] @relation("ProcessedBy")
  approvalRequests          TemplateApprovalRequest[] @relation("ApprovalRequests")
  usuarioChatwit            UsuarioChatwit?
}

model Account {
  id                String        @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  igUserId          String?
  igUsername        String?
  isMain            Boolean       @default(false)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  agendamentos      Agendamento[]
  automacoes        Automacao[]
  chats             Chat[]
  leads             Lead[]

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Lead {
  id               String                @id @default(cuid())
  name             String?
  email            String?
  phone            String?
  avatarUrl        String?
  source           LeadSource
  sourceIdentifier String
  tags             String[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  userId           String?
  accountId        String?
  chats            Chat[]
  disparos         DisparoMtfDiamante[]
  account          Account?              @relation(fields: [accountId], references: [id])
  user             User?                 @relation(fields: [userId], references: [id])
  automacoes       LeadAutomacao[]
  instagramProfile LeadInstagramProfile?
  oabData          LeadOabData?

  @@unique([source, sourceIdentifier, accountId])
  @@index([userId, accountId, email, phone])
  @@index([tags])
}

model LeadInstagramProfile {
  id            String    @id @default(cuid())
  leadId        String    @unique
  isFollower    Boolean   @default(false)
  lastMessageAt DateTime?
  isOnline      Boolean   @default(false)
  lead          Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadOabData {
  id                     String                 @id @default(cuid())
  leadId                 String                 @unique
  nomeReal               String?
  concluido              Boolean                @default(false)
  anotacoes              String?
  pdfUnificado           String?
  imagensConvertidas     String?
  leadUrl                String?
  fezRecurso             Boolean                @default(false)
  datasRecurso           String?
  provaManuscrita        Json?
  manuscritoProcessado   Boolean                @default(false)
  aguardandoManuscrito   Boolean                @default(false)
  espelhoCorrecao        String?
  textoDOEspelho         Json?
  espelhoProcessado      Boolean                @default(false)
  aguardandoEspelho      Boolean                @default(false)
  analiseUrl             String?
  argumentacaoUrl        String?
  analiseProcessada      Boolean                @default(false)
  aguardandoAnalise      Boolean                @default(false)
  analisePreliminar      Json?
  analiseValidada        Boolean                @default(false)
  consultoriaFase2       Boolean                @default(false)
  recursoPreliminar      Json?
  recursoValidado        Boolean                @default(false)
  recursoUrl             String?
  recursoArgumentacaoUrl String?
  aguardandoRecurso      Boolean                @default(false)
  seccional              String?
  areaJuridica           String?
  notaFinal              Float?
  situacao               String?
  inscricao              String?
  examesParticipados     Json?
  especialidade          EspecialidadeJuridica?
  usuarioChatwitId       String
  espelhoBibliotecaId    String?
  arquivos               ArquivoLeadOab[]
  espelhoBiblioteca      EspelhoBiblioteca?     @relation(fields: [espelhoBibliotecaId], references: [id])
  lead                   Lead                   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  usuarioChatwit         UsuarioChatwit         @relation(fields: [usuarioChatwitId], references: [id], onDelete: Cascade)

  @@index([usuarioChatwitId, espelhoBibliotecaId])
}

model ArquivoLeadOab {
  id            String      @id @default(cuid())
  leadOabDataId String
  fileType      String
  dataUrl       String
  pdfConvertido String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  leadOabData   LeadOabData @relation(fields: [leadOabDataId], references: [id], onDelete: Cascade)

  @@index([leadOabDataId])
}

model UsuarioChatwit {
  id                         String                @id @default(cuid())
  appUserId                  String                @unique
  name                       String
  availableName              String?
  accountName                String
  channel                    String
  chatwitAccessToken         String?               @unique
  chatwitAccountId           String
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt
  agentesDialogflow          AgenteDialogflow[]
  inboxes                    ChatwitInbox[]
  espelhosBiblioteca         EspelhoBiblioteca[]
  espelhosPadrao             EspelhoPadrao[]
  leadsOabData               LeadOabData[]
  appUser                    User                  @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  configuracaoGlobalWhatsApp WhatsAppGlobalConfig?
}

model WhatsAppGlobalConfig {
  id                        String         @id @default(cuid())
  usuarioChatwitId          String         @unique
  whatsappApiKey            String
  phoneNumberId             String
  whatsappBusinessAccountId String
  graphApiBaseUrl           String         @default("https://graph.facebook.com/v22.0")
  updatedAt                 DateTime       @updatedAt
  usuarioChatwit            UsuarioChatwit @relation(fields: [usuarioChatwitId], references: [id], onDelete: Cascade)
}

model ChatwitInbox {
  id                        String               @id @default(cuid())
  nome                      String
  inboxId                   String
  channelType               String
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  usuarioChatwitId          String
  whatsappApiKey            String?
  phoneNumberId             String?
  whatsappBusinessAccountId String?
  fallbackParaInboxId       String?
  agentes                   AgenteDialogflow[]
  fallbackParaInbox         ChatwitInbox?        @relation("FallbackInbox", fields: [fallbackParaInboxId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fallbackDeInboxes         ChatwitInbox[]       @relation("FallbackInbox")
  usuarioChatwit            UsuarioChatwit       @relation(fields: [usuarioChatwitId], references: [id], onDelete: Cascade)
  mapeamentosBotoes         MapeamentoBotao[]
  mapeamentosIntencao       MapeamentoIntencao[]
  templates                 Template[]

  @@unique([usuarioChatwitId, inboxId])
}

model Template {
  id                   String                    @id @default(cuid())
  name                 String
  description          String?
  type                 TemplateType
  scope                TemplateScope             @default(PRIVATE)
  status               TemplateStatus            @default(APPROVED)
  language             String                    @default("pt_BR")
  tags                 String[]
  isActive             Boolean                   @default(true)
  usageCount           Int                       @default(0)
  simpleReplyText      String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  createdById          String
  inboxId              String?
  interactiveContent   InteractiveContent?
  mapeamentos          MapeamentoIntencao[]
  createdBy            User                      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  inbox                ChatwitInbox?             @relation(fields: [inboxId], references: [id])
  approvalRequests     TemplateApprovalRequest[]
  whatsappOfficialInfo WhatsAppOfficialInfo?

  @@index([createdById, inboxId, type, scope, status, isActive])
}

model TemplateApprovalRequest {
  id              String    @id @default(cuid())
  templateId      String
  status          String    @default("pending")
  requestMessage  String?
  responseMessage String?
  requestedById   String
  processedById   String?
  requestedAt     DateTime  @default(now())
  processedAt     DateTime?
  processedBy     User?     @relation("ProcessedBy", fields: [processedById], references: [id])
  requestedBy     User      @relation("ApprovalRequests", fields: [requestedById], references: [id], onDelete: Cascade)
  template        Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, requestedById, status])
}

model MapeamentoBotao {
  id            String       @id @default(cuid())
  buttonId      String       @unique
  actionType    ActionType
  actionPayload Json
  description   String?
  inboxId       String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  inbox         ChatwitInbox @relation(fields: [inboxId], references: [id], onDelete: Cascade)

  @@index([inboxId])
}

model InteractiveContent {
  id                    String                 @id @default(cuid())
  templateId            String                 @unique
  bodyId                String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  actionCtaUrl          ActionCtaUrl?
  actionFlow            ActionFlow?
  actionList            ActionList?
  actionLocationRequest ActionLocationRequest?
  actionReplyButton     ActionReplyButton?
  footer                Footer?
  header                Header?
  body                  Body                   @relation(fields: [bodyId], references: [id])
  template              Template               @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model WhatsAppOfficialInfo {
  id             String   @id @default(cuid())
  templateId     String   @unique
  metaTemplateId String
  status         String
  category       String
  qualityScore   String?
  components     Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  template       Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([metaTemplateId, status])
}

model Header {
  id                   String             @id @default(cuid())
  type                 String
  content              String
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)
}

model Body {
  id                  String               @id @default(cuid())
  text                String
  interactiveContents InteractiveContent[]
}

model Footer {
  id                   String             @id @default(cuid())
  text                 String
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)
}

model ActionCtaUrl {
  id                   String             @id @default(cuid())
  displayText          String
  url                  String
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)
}

model ActionReplyButton {
  id                   String             @id @default(cuid())
  buttons              Json
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)
}

model ActionList {
  id                   String             @id @default(cuid())
  buttonText           String
  sections             Json
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)
}

model ActionFlow {
  id                   String             @id @default(cuid())
  flowId               String
  flowCta              String
  flowMode             String             @default("published")
  flowData             Json?
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)
}

model ActionLocationRequest {
  id                   String             @id @default(cuid())
  requestText          String
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)
}

model AgenteDialogflow {
  id               String         @id @default(cuid())
  nome             String
  projectId        String
  credentials      String
  region           String         @default("global")
  hookId           String?
  ativo            Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  usuarioChatwitId String
  inboxId          String
  inbox            ChatwitInbox   @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  usuarioChatwit   UsuarioChatwit @relation(fields: [usuarioChatwitId], references: [id], onDelete: Cascade)
}

model MapeamentoIntencao {
  id         String       @id @default(cuid())
  intentName String
  inboxId    String
  templateId String
  inbox      ChatwitInbox @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  template   Template     @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([intentName, inboxId])
}

model Automacao {
  id               String          @id @default(cuid())
  userId           String
  folderId         String?
  accountId        String
  selectedMediaId  String?
  anyMediaSelected Boolean         @default(false)
  anyword          Boolean         @default(true)
  palavrasChave    String?
  fraseBoasVindas  String?
  publicReply      String?
  buttonPayload    String          @unique
  live             Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  account          Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  folder           Pasta?          @relation(fields: [folderId], references: [id])
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadsAutomacao   LeadAutomacao[]

  @@index([userId, accountId])
}

model LeadAutomacao {
  id              String    @id @default(cuid())
  leadId          String
  automacaoId     String
  linkSent        Boolean   @default(false)
  waitingForEmail Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  automacao       Automacao @relation(fields: [automacaoId], references: [id], onDelete: Cascade)
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, automacaoId])
}

model MtfDiamanteConfig {
  id        String                @id @default(cuid())
  userId    String                @unique
  isActive  Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  variaveis MtfDiamanteVariavel[]
}

model MtfDiamanteVariavel {
  id        String            @id @default(cuid())
  configId  String
  chave     String
  valor     Json
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  config    MtfDiamanteConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, chave])
}

model DisparoMtfDiamante {
  id           String    @id @default(cuid())
  userId       String
  templateName String
  leadId       String
  status       String    @default("PENDING")
  scheduledAt  DateTime?
  sentAt       DateTime?
  parameters   Json?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, leadId])
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model ResetPasswordToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model Pasta {
  id         String      @id @default(cuid())
  name       String
  userId     String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  automacoes Automacao[]
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  stripeSubscriptionId String             @unique
  stripeCustomerId     String
  status               SubscriptionStatus
  startDate            DateTime
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Agendamento {
  id                             String   @id @default(cuid())
  userId                         String
  accountId                      String
  data                           DateTime
  descricao                      String?
  facebook                       Boolean  @default(false)
  instagram                      Boolean  @default(false)
  linkedin                       Boolean  @default(false)
  x                              Boolean  @default(false)
  stories                        Boolean  @default(false)
  reels                          Boolean  @default(false)
  postNormal                     Boolean  @default(false)
  diario                         Boolean  @default(false)
  semanal                        Boolean  @default(false)
  randomizar                     Boolean  @default(false)
  tratarComoUnicoPost            Boolean  @default(false)
  tratarComoPostagensIndividuais Boolean  @default(false)
  concluidoFB                    Boolean  @default(false)
  concluidoIG                    Boolean  @default(false)
  concluidoLK                    Boolean  @default(false)
  concluidoX                     Boolean  @default(false)
  createdAt                      DateTime @default(now())
  account                        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user                           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  midias                         Midia[]
}

model Midia {
  id            String      @id @default(cuid())
  agendamentoId String
  url           String
  mime_type     String
  thumbnail_url String?
  contador      Int         @default(0)
  createdAt     DateTime    @default(now())
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)

  @@index([agendamentoId])
}

model Chat {
  id        String    @id @default(cuid())
  leadId    String
  accountId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([leadId, accountId])
}

model Message {
  id         String   @id @default(cuid())
  chatId     String
  content    String
  isFromLead Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
}

model ChatSession {
  id              String           @id @default(cuid())
  userId          String
  title           String           @default("Nova conversa")
  model           String           @default("chatgpt-4o-latest")
  summary         String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  files           ChatFile[]
  messages        ChatMessage[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedImages GeneratedImage[]

  @@index([userId])
}

model ChatMessage {
  id              String      @id @default(cuid())
  sessionId       String
  role            String
  content         String
  contentType     String      @default("text")
  audioData       String?
  imageUrl        String?
  modelUsed       String?
  inputTokens     Int?
  outputTokens    Int?
  totalTokens     Int?
  reasoningTokens Int?
  temperature     Float?
  topP            Float?
  responseStatus  String?
  createdAt       DateTime    @default(now())
  session         ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model ChatFile {
  id            String      @id @default(cuid())
  sessionId     String
  storageUrl    String
  openaiFileId  String?
  status        String      @default("stored")
  purpose       String?
  thumbnail_url String?
  filename      String
  fileType      String
  createdAt     DateTime    @default(now())
  syncedAt      DateTime?
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, openaiFileId])
}

model GeneratedImage {
  id            String       @id @default(cuid())
  userId        String
  sessionId     String?
  prompt        String
  revisedPrompt String?
  model         String
  imageUrl      String
  thumbnailUrl  String?
  mimeType      String       @default("image/png")
  size          String?
  quality       String?
  openaiFileId  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  session       ChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId])
}

model EspelhoBiblioteca {
  id                          String         @id @default(cuid())
  nome                        String
  descricao                   String?
  textoDOEspelho              Json?
  espelhoCorrecao             String?
  isAtivo                     Boolean        @default(true)
  totalUsos                   Int            @default(0)
  espelhoBibliotecaProcessado Boolean        @default(false)
  aguardandoEspelho           Boolean        @default(false)
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt
  criadoPorId                 String
  criadoPor                   UsuarioChatwit @relation(fields: [criadoPorId], references: [id], onDelete: Cascade)
  leadsOabData                LeadOabData[]

  @@index([criadoPorId, isAtivo])
}

model EspelhoPadrao {
  id                      String                @id @default(cuid())
  especialidade           EspecialidadeJuridica @unique
  nome                    String
  descricao               String?
  textoMarkdown           String?
  espelhoCorrecao         String?
  isAtivo                 Boolean               @default(true)
  totalUsos               Int                   @default(0)
  processado              Boolean               @default(false)
  aguardandoProcessamento Boolean               @default(false)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  atualizadoPorId         String
  atualizadoPor           UsuarioChatwit        @relation(fields: [atualizadoPorId], references: [id], onDelete: Cascade)

  @@index([isAtivo])
}

model ModeloRecurso {
  id        String   @id @default(cuid())
  texto     String
  isGlobal  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isGlobal])
}

model WebhookMessage {
  id                String   @id @default(cuid())
  whatsappMessageId String
  conversationId    String
  contactPhone      String
  messageContent    String
  messageType       String   @default("text")
  inboxId           String
  rawPayload        Json
  processed         Boolean  @default(false)
  timestamp         DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([whatsappMessageId, conversationId, contactPhone, processed])
}

model ConversationThread {
  id                     String   @id @default(cuid())
  whatsappConversationId String   @unique
  contactPhone           String
  lastMessageAt          DateTime
  status                 String   @default("active")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([contactPhone, lastMessageAt])
}

model FeatureFlag {
  id                String   @id @default(cuid())
  name              String   @unique
  description       String
  enabled           Boolean  @default(false)
  rolloutPercentage Int      @default(0)
  conditions        Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  createdBy         String
}

model UserFeedback {
  id                 String   @id @default(cuid())
  userId             String
  userEmail          String?
  type               String
  category           String
  title              String
  description        String
  severity           String
  status             String   @default("OPEN")
  metadata           Json     @default("{}")
  featureFlagContext Json?
  systemContext      Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([type, severity, status])
  @@index([createdAt])
}

model QueueConfig {
  id              String   @id @default(cuid())
  name            String   @unique @db.VarChar(255)
  displayName     String?  @db.VarChar(255)
  description     String?
  priority        Int      @default(0)
  concurrency     Int      @default(1)
  rateLimiter     Json?
  retryPolicy     Json
  cleanupPolicy   Json
  alertThresholds Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String   @db.VarChar(255)

  @@index([name, priority])
}

model QueueMetrics {
  id                  String   @id @default(cuid())
  queueName           String   @db.VarChar(255)
  timestamp           DateTime
  waitingCount        Int
  activeCount         Int
  completedCount      Int
  failedCount         Int
  delayedCount        Int
  throughputPerMinute Decimal? @db.Decimal(10, 2)
  avgProcessingTime   Decimal? @db.Decimal(10, 2)
  successRate         Decimal? @db.Decimal(5, 2)
  errorRate           Decimal? @db.Decimal(5, 2)
  memoryUsage         BigInt?
  cpuUsage            Decimal? @db.Decimal(5, 2)
  createdAt           DateTime @default(now())

  @@index([queueName, timestamp(sort: Desc)])
  @@index([timestamp(sort: Desc)])
}

model JobMetrics {
  id             String    @id @default(cuid())
  jobId          String    @db.VarChar(255)
  queueName      String    @db.VarChar(255)
  jobName        String?   @db.VarChar(255)
  jobType        String?   @db.VarChar(255)
  status         JobState
  createdAt      DateTime
  startedAt      DateTime?
  completedAt    DateTime?
  processingTime Int?
  waitTime       Int?
  attempts       Int       @default(0)
  maxAttempts    Int       @default(1)
  memoryPeak     BigInt?
  cpuTime        Int?
  errorMessage   String?
  correlationId  String?   @db.VarChar(255)
  flowId         String?   @db.VarChar(255)
  parentJobId    String?   @db.VarChar(255)
  payloadSize    Int?
  resultSize     Int?

  @@index([queueName, status])
  @@index([correlationId])
  @@index([flowId])
  @@index([createdAt(sort: Desc)])
}

model AlertRule {
  id          String        @id @default(cuid())
  name        String        @db.VarChar(255)
  description String?
  queueName   String?       @db.VarChar(255)
  condition   Json
  severity    AlertSeverity
  channels    Json
  cooldown    Int           @default(5)
  enabled     Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdBy   String        @db.VarChar(255)
  alerts      Alert[]

  @@index([queueName, enabled])
}

model Alert {
  id             String        @id @default(cuid())
  ruleId         String
  queueName      String?       @db.VarChar(255)
  severity       AlertSeverity
  title          String        @db.VarChar(500)
  message        String
  metrics        Json?
  status         AlertStatus   @default(active)
  createdAt      DateTime      @default(now())
  acknowledgedAt DateTime?
  acknowledgedBy String?       @db.VarChar(255)
  resolvedAt     DateTime?
  resolutionNote String?
  rule           AlertRule     @relation(fields: [ruleId], references: [id])

  @@index([ruleId, status])
  @@index([severity, createdAt(sort: Desc)])
}

model JobFlow {
  id                  String          @id @default(cuid())
  flowId              String          @unique @db.VarChar(255)
  name                String?         @db.VarChar(255)
  description         String?
  rootJobId           String          @db.VarChar(255)
  status              String          @default("pending") @db.VarChar(20)
  totalJobs           Int             @default(0)
  completedJobs       Int             @default(0)
  failedJobs          Int             @default(0)
  startedAt           DateTime?
  completedAt         DateTime?
  estimatedCompletion DateTime?
  createdAt           DateTime        @default(now())
  metadata            Json?
  dependencies        JobDependency[]

  @@index([status, createdAt(sort: Desc)])
}

model JobDependency {
  id             String   @id @default(cuid())
  flowId         String   @db.VarChar(255)
  jobId          String   @db.VarChar(255)
  parentJobId    String?  @db.VarChar(255)
  dependencyType String   @default("sequential") @db.VarChar(50)
  condition      Json?
  createdAt      DateTime @default(now())
  flow           JobFlow  @relation(fields: [flowId], references: [flowId])

  @@index([flowId, jobId])
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique @db.VarChar(255)
  value       Json
  description String?
  category    String?  @db.VarChar(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   String?  @db.VarChar(255)

  @@index([category])
}

model QueueUser {
  id          String        @id @default(cuid())
  userId      String        @unique @db.VarChar(255)
  email       String        @db.VarChar(255)
  name        String        @db.VarChar(255)
  role        QueueUserRole @default(viewer)
  permissions Json?
  queueAccess Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lastLogin   DateTime?

  @@index([role, email])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String   @db.VarChar(255)
  action       String   @db.VarChar(255)
  resourceType String   @db.VarChar(100)
  resourceId   String?  @db.VarChar(255)
  queueName    String?  @db.VarChar(255)
  details      Json?
  ipAddress    String?  @db.Inet
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@index([resourceType, resourceId])
}

model AutomationPolicy {
  id               String    @id @default(cuid())
  name             String    @db.VarChar(255)
  description      String?
  queueName        String?   @db.VarChar(255)
  triggerCondition Json
  actions          Json
  enabled          Boolean   @default(true)
  priority         Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdBy        String    @db.VarChar(255)
  lastExecuted     DateTime?
  executionCount   Int       @default(0)

  @@index([enabled, priority])
  @@index([queueName])
}

model WebhookConfig {
  id          String            @id @default(cuid())
  name        String            @db.VarChar(255)
  url         String            @db.VarChar(1000)
  events      Json
  headers     Json?
  secret      String?           @db.VarChar(255)
  enabled     Boolean           @default(true)
  retryPolicy Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  createdBy   String            @db.VarChar(255)
  deliveries  WebhookDelivery[]

  @@index([enabled])
}

model WebhookDelivery {
  id             String        @id @default(cuid())
  webhookId      String
  eventType      WebhookEvent
  payload        Json
  responseStatus Int?
  responseBody   String?
  attempts       Int           @default(1)
  deliveredAt    DateTime?
  createdAt      DateTime      @default(now())
  webhook        WebhookConfig @relation(fields: [webhookId], references: [id])

  @@index([webhookId, eventType])
  @@index([createdAt(sort: Desc)])
}


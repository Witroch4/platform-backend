/// Configuração do Agente de IA ("Capitão") por usuário/owner
model AiAgentConfig {
  id                  String   @id @default(cuid())
  ownerId             String   @unique
  name                String   @default("Capitão")
  provider            String   @default("openai")
  model               String   @default("gpt-4o-mini")
  systemPrompt        String?
  immutableDirectives Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  owner               User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model AiAgentBlueprint {
  id              String        @id @default(cuid())
  ownerId         String
  name            String
  description     String?
  agentType       AiAgentType   @default(TOOLS)
  icon            String?
  model           String        @default("gpt-4o-mini")
  temperature     Float?        @default(0.7)
  topP            Float?
  maxOutputTokens Int?          @default(1024)
  systemPrompt    String?
  instructions    String?
  toolset         Json?
  outputParser    Json?
  memory          Json?
  canvasState     Json?
  metadata        Json?
  // Engine Híbrida: vinculação de agente a coluna da tabela
  linkedColumn    LinkedColumn? // Coluna da tabela que este agente executa
  defaultProvider AiProvider?   // Provedor padrão (OPENAI ou GEMINI)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  owner           User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([agentType])
  @@index([linkedColumn])
}

model AiAssistant {
  id                      String               @id @default(cuid())
  userId                  String
  name                    String
  description             String?
  productName             String?
  generateFaqs            Boolean              @default(false)
  captureMemories         Boolean              @default(false)
  instructions            String?
  intentOutputFormat      AiIntentOutputFormat @default(JSON)
  model                   String               @default("gpt-5-nano")
  embedipreview           Boolean              @default(true)
  reasoningEffort         String               @default("minimal")
  verbosity               String               @default("low")
  temperature             Float?               @default(0.7)
  topP                    Float?               @default(0.7)
  tempSchema              Float                @default(0.1)
  tempCopy                Float                @default(0.4)
  maxOutputTokens         Int                  @default(648)
  warmupDeadlineMs        Int                  @default(15000)
  hardDeadlineMs          Int                  @default(15000)
  softDeadlineMs          Int                  @default(18000)
  shortTitleLLM           Boolean              @default(true)
  toolChoice              String               @default("auto")
  proposeHumanHandoff     Boolean              @default(true)
  disableIntentSuggestion Boolean              @default(false)
  enableAutoRemarketing   Boolean              @default(false)
  remarketingDelayMinutes Int                  @default(30)
  remarketingMessage      String?
  sessionTtlSeconds       Int                  @default(86400)  // 24h default
  sessionTtlDevSeconds    Int                  @default(300)    // 5min default
  isActive                Boolean              @default(true)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  user                    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  inboxLinks              AiAssistantInbox[]
  documents               AiDocument[]
  faqs                    AiFaq[]
  abTests                 PromptABTest[]
  promptVersions          PromptVersion[]

  @@index([userId, isActive])
}

model AiAssistantInbox {
  id          String       @id @default(cuid())
  assistantId String
  inboxDbId   String
  createdAt   DateTime     @default(now())
  isActive    Boolean      @default(true)
  assistant   AiAssistant  @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  inbox       ChatwitInbox @relation(fields: [inboxDbId], references: [id], onDelete: Cascade)

  @@unique([assistantId, inboxDbId])
}

model AiDocument {
  id          String                 @id @default(cuid())
  userId      String
  assistantId String?
  title       String
  sourceUrl   String?
  contentText String?
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  embedding   Unsupported("vector")?
  assistant   AiAssistant?           @relation(fields: [assistantId], references: [id])
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, assistantId, isActive])
  @@index([embedding])
}

model AiFaq {
  id              String       @id @default(cuid())
  userId          String
  assistantId     String?
  question        String
  answer          String?
  status          AiFaqStatus  @default(PENDING)
  autoGenerated   Boolean      @default(false)
  sourceMessageId String?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  assistant       AiAssistant? @relation(fields: [assistantId], references: [id])
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, assistantId, status, isActive])
}

model IframeAuthorizedDomain {
  id          String   @id @default(cuid())
  domain      String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String
  user        User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([createdBy])
}

// =============================================================================
// FLOW ENGINE — Motor de execução de flows de mensagens interativas
// =============================================================================

model Flow {
  id          String               @id @default(cuid())
  name        String
  inboxId     String
  isActive    Boolean              @default(true)
  canvasJson  Json?                // Canvas visual (nodes/edges/viewport) específico deste flow
  nodes       FlowNode[]
  edges       FlowEdge[]
  sessions    FlowSession[]
  mapeamentos MapeamentoIntencao[] // Mapeamentos de intent que apontam para este flow
  inbox       ChatwitInbox         @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([inboxId, isActive])
}

model FlowNode {
  id        String     @id @default(cuid())
  flowId    String
  flow      Flow       @relation(fields: [flowId], references: [id], onDelete: Cascade)
  nodeType  String     // START, TEXT_MESSAGE, INTERACTIVE_MESSAGE, DELAY, CONDITION, etc.
  config    Json       // Configuração específica do nó
  positionX Float
  positionY Float
  outEdges  FlowEdge[] @relation("SourceNode")
  inEdges   FlowEdge[] @relation("TargetNode")

  @@index([flowId])
}

model FlowEdge {
  id              String   @id @default(cuid())
  flowId          String
  flow            Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  sourceNodeId    String
  targetNodeId    String
  sourceNode      FlowNode @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode      FlowNode @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)
  buttonId        String?  // Para edges que saem de botões
  conditionBranch String?  // "true" ou "false" para CONDITION nodes

  @@index([flowId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
}

model FlowSession {
  id             String            @id @default(cuid())
  flowId         String
  flow           Flow              @relation(fields: [flowId], references: [id])
  conversationId String
  contactId      String
  inboxId        String
  status         FlowSessionStatus @default(ACTIVE)
  currentNodeId  String?           // Nó atual (para WAITING_INPUT)
  variables      Json              @default("{}")
  executionLog   Json              @default("[]")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  completedAt    DateTime?

  @@index([conversationId])
  @@index([status])
  @@index([flowId])
  @@index([inboxId, status])
  @@index([createdAt])
}

enum FlowSessionStatus {
  ACTIVE
  WAITING_INPUT
  COMPLETED
  ERROR
}


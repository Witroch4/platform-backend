datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

enum UserRole {
  DEFAULT
  ADMIN
  SUPERADMIN
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
}

model User {
  id                     String    @id @default(cuid())
  name                   String?
  email                  String    @unique
  emailVerified          DateTime?
  image                  String?
  role                   UserRole  @default(DEFAULT)
  password               String?
  isTwoFactorAuthEnabled Boolean   @default(false)
  twoFactorAuthVerified  DateTime?
  accounts               Account[]
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  isNew                  Boolean   @default(true)

  // Relação com assinaturas
  subscriptions Subscription[]

  // Relação com Automacoes
  automacoes Automacao[]

  // Relação com Pastas
  pastas Pasta[]

  // Relação com Notificações
  notifications Notification[]

  // Novo modelo para Agendamentos
  agendamentos Agendamento[]

  // Relação com sessões de chat de IA
  chatSessions ChatSession[]

  // Relação com imagens geradas por IA
  generatedImages GeneratedImage[]

  // Relação com configurações do MTF Diamante
  mtfDiamanteConfigs MtfDiamanteConfig[]

  // Relação com disparos do MTF Diamante
  disparosMtfDiamante DisparoMtfDiamante[]

  // Controle de seed executado para MTF Diamante
  mtfDiamanteSeedExecuted Boolean @default(false)
  
  // Controle de variáveis MTF Diamante populadas
  mtfVariaveisPopuladas Boolean @default(false)

  // Relação 1-para-1 com UsuarioChatwit
  usuarioChatwit UsuarioChatwit?

  // Template Library relationships
  createdTemplates     TemplateLibrary[]        @relation("CreatedTemplates")
  requestedApprovals   TemplateApprovalRequest[] @relation("RequestedApprovals")
  processedApprovals   TemplateApprovalRequest[] @relation("ProcessedApprovals")
  
  // Interactive Messages relationships
  createdInteractiveMessages InteractiveMessage[]
  
  // Unified Template System relationships
  templates Template[] @relation("CreatedTemplates")
}



model Account {
  id                String      @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?     @db.Text
  access_token      String?     @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?     @db.Text
  session_state     String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  igUserId          String?
  igUsername        String? // Nome de usuário do Instagram
  isMain            Boolean     @default(false) // Indica se é a conta principal
  automacoes        Automacao[]
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relações para o chat
  leads Lead[]
  chats Chat[]

  // Novo modelo para Agendamentos
  agendamentos Agendamento[]

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String   @unique
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorToken {
  id      String   @id @default(cuid())
  email   String   @unique
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model ResetPasswordToken {
  id      String   @id @default(cuid())
  email   String   @unique
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

/**
 * Automacao
 * - Fica igual ao que você já tinha, exceto que removemos "customerEmail" se não for mais necessário.
 */
model Automacao {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relacionamento opcional com Pasta (se existir)
  folderId String?
  folder   Pasta?  @relation(fields: [folderId], references: [id])

  // Relacionamento com conta do Instagram (obrigatório)
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  selectedMediaId     String?
  anyMediaSelected    Boolean  @default(false)
  anyword             Boolean  @default(true)
  palavrasChave       String?
  fraseBoasVindas     String?
  quickReplyTexto     String?
  mensagemEtapa3      String?
  linkEtapa3          String?
  legendaBotaoEtapa3  String?
  responderPublico    Boolean  @default(false)
  pedirEmailPro       Boolean  @default(false)
  emailPrompt         String?
  pedirParaSeguirPro  Boolean  @default(false)
  followPrompt        String?
  followButtonPayload String?
  contatoSemClique    Boolean  @default(false)
  noClickPrompt       String?
  publicReply         String?
  buttonPayload       String   @unique
  live                Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  leadsAutomacao LeadAutomacao[]

  @@index([userId])
  @@index([accountId])
}

/**
 * Lead
 * - Agora somente guarda dados *gerais* do lead (e.g. e-mail, whatsapp).
 * - Fica com igSenderId como PK.
 * - Remove campos automacaoId, linkSent, waitingForEmail etc.
 */
model Lead {
  igSenderId  String    @id @default(cuid())
  email       String?
  whatsapp    String?
  seguidor    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  name        String? // Nome do lead
  avatar      String? // URL do avatar do lead
  lastMessage DateTime? // Data da última mensagem
  isOnline    Boolean   @default(false) // Status online/offline
  accountId   String // ID da conta do Instagram
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Relações
  automacoesLead LeadAutomacao[]
  chats          Chat[]

  @@index([accountId])
}

/**
 * Tabela intermediária para 'Lead' participar de várias 'Automacao'.
 * Armazena status *por automação*, como linkSent, waitingForEmail, etc.
 */
model LeadAutomacao {
  id              String   @id @default(cuid())
  leadIgSenderId  String
  automacaoId     String
  linkSent        Boolean  @default(false)
  waitingForEmail Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relações
  lead      Lead      @relation(fields: [leadIgSenderId], references: [igSenderId], onDelete: Cascade)
  automacao Automacao @relation(fields: [automacaoId], references: [id], onDelete: Cascade)

  // Garante que não haja duplicado de (Lead, Automacao)
  @@unique([leadIgSenderId, automacaoId])
}

model Pasta {
  id        String   @id @default(cuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  automacoes Automacao[]
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String             @unique
  stripeCustomerId     String
  status               SubscriptionStatus
  startDate            DateTime
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

// Modelo para o sistema de notificações
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Novo modelo para Agendamento
model Agendamento {
  id        String  @id @default(cuid())
  userId    String // ID do usuário responsável pelo agendamento
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId String // ID da conta vinculada ao agendamento (Instagram, Facebook, etc.)
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  Data                           DateTime // Data e hora do agendamento
  Descricao                      String? // Descrição da postagem
  Facebook                       Boolean  @default(false)
  Instagram                      Boolean  @default(false)
  Linkedin                       Boolean  @default(false)
  X                              Boolean  @default(false)
  Stories                        Boolean  @default(false)
  Reels                          Boolean  @default(false)
  PostNormal                     Boolean  @default(false)
  Diario                         Boolean  @default(false)
  Semanal                        Boolean  @default(false)
  Randomizar                     Boolean  @default(false)
  TratarComoUnicoPost            Boolean  @default(false) // Todas as mídias em um único post
  TratarComoPostagensIndividuais Boolean  @default(false) // Cada mídia postada individualmente
  Concluido_FB                   Boolean  @default(false)
  Concluido_IG                   Boolean  @default(false)
  Concluido_LK                   Boolean  @default(false)
  Concluido_X                    Boolean  @default(false)
  createdAt                      DateTime @default(now())

  // Relação com mídias
  midias Midia[]
}

// Novo modelo para Midia
model Midia {
  id            String      @id @default(cuid())
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
  agendamentoId String
  url           String // URL da mídia no MinIO
  mime_type     String // Tipo da mídia (ex.: image/jpeg, video/mp4)
  thumbnail_url String? // URL da thumbnail no MinIO (opcional)
  contador      Int         @default(0) // Número de vezes que a mídia foi enviada
  createdAt     DateTime    @default(now())

  @@index([agendamentoId])
}

model Chat {
  id        String    @id @default(cuid())
  leadId    String
  lead      Lead      @relation(fields: [leadId], references: [igSenderId], onDelete: Cascade)
  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@unique([leadId, accountId])
  @@index([accountId])
}

model Message {
  id         String   @id @default(cuid())
  chatId     String
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  content    String
  isFromLead Boolean  @default(true) // true = mensagem do lead, false = mensagem do usuário
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([chatId])
}

// Modelos para o sistema de Gestão de Leads (Chatwit)

model UsuarioChatwit {
  id String @id @default(cuid())

  // Relação 1-para-1 com User (chave principal)
  appUserId String @unique // Garante que um User só tenha um UsuarioChatwit
  appUser   User   @relation(fields: [appUserId], references: [id], onDelete: Cascade)

  // Campos do sistema externo (Chatwit)
  name          String
  availableName String?
  accountName   String
  channel       String // Ex: "Whatsapp"

  // CAMPOS MOVIDOS DO USER
  chatwitAccessToken String? @unique // Token de acesso do Chatwit
  chatwitAccountId   String // ID da conta no Chatwit (obrigatório)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relação com leads
  leads LeadChatwit[]

  // Relação com espelhos da biblioteca
  espelhosBiblioteca EspelhoBiblioteca[]

  // Relação com espelhos padrão
  espelhosPadrao EspelhoPadrao[]

  // NOVOS RELACIONAMENTOS MOVIDOS DO USER
  // Relação com configurações do WhatsApp
  whatsappConfigs WhatsAppConfig[]

  // Relação com templates do WhatsApp
  whatsappTemplates WhatsAppTemplate[]

  // Relacionamentos com WhatsApp/Dialogflow
  lotesOab              LoteOab[]
  mensagensInterativas  MensagemInterativa[]
  leadsOab              LeadOab[]
  caixasEntrada         CaixaEntrada[]
  agentesDialogflow     AgenteDialogflow[]
}

// Enum para especialidades jurídicas
enum EspecialidadeJuridica {
  ADMINISTRATIVO
  CIVIL
  CONSTITUCIONAL
  TRABALHO
  EMPRESARIAL
  PENAL
  TRIBUTARIO
}

// New enums for unified Template system
enum TemplateType {
  WHATSAPP_OFFICIAL     // Official Meta-approved template
  INTERACTIVE_MESSAGE   // Custom interactive message
  AUTOMATION_REPLY      // Simple text for automations
}

enum TemplateScope {
  GLOBAL    // Available to all users
  PRIVATE   // Only for creator
}

enum PlatformType {
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  X
}

enum PostType {
  POST
  STORIES
  REELS
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
}

// Unified Template System Models
model Template {
  id          String       @id @default(cuid())
  name        String
  type        TemplateType
  scope       TemplateScope @default(PRIVATE)
  description String?
  tags        String[]
  language    String       @default("pt_BR")
  isActive    Boolean      @default(true)
  usageCount  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relationships
  createdById String
  createdBy   User         @relation("CreatedTemplates", fields: [createdById], references: [id], onDelete: Cascade)
  caixaId     String?
  caixa       CaixaEntrada? @relation(fields: [caixaId], references: [id], onDelete: SetNull)

  // Content relationships (only one will be populated based on type)
  interactiveContent   InteractiveContent?
  whatsappOfficialInfo WhatsAppOfficialInfo?

  // Mappings
  mapeamentos MapeamentoIntencao[] @relation("TemplateMappings")
  approvalRequests TemplateApprovalRequest[] @relation("TemplateApprovals")

  @@index([createdById])
  @@index([caixaId])
  @@index([type])
  @@index([scope])
  @@index([isActive])
}

// Interactive Content Structure (replaces MensagemInterativa functionality)
model InteractiveContent {
  id          String   @id @default(cuid())
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId  String   @unique

  // Visual components
  header   Header?
  body     Body     @relation(fields: [bodyId], references: [id])
  bodyId   String
  footer   Footer?

  // Actions (only one will be populated based on message type)
  actionCtaUrl           ActionCtaUrl?
  actionReplyButton      ActionReplyButton?
  actionList             ActionList?
  actionFlow             ActionFlow?
  actionLocationRequest  ActionLocationRequest?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templateId])
}

// Component Models for Interactive Content
model Header {
  id                   String             @id @default(cuid())
  type                 String             // 'text', 'image', 'video', 'document'
  content              String             @db.Text
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Body {
  id                   String             @id @default(cuid())
  text                 String             @db.Text
  interactiveContents  InteractiveContent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Footer {
  id                   String             @id @default(cuid())
  text                 String
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Action Models for Interactive Content
model ActionCtaUrl {
  id                   String             @id @default(cuid())
  displayText          String
  url                  String
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActionReplyButton {
  id                   String             @id @default(cuid())
  buttons              Json               // Array of button objects
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActionList {
  id                   String             @id @default(cuid())
  buttonText           String
  sections             Json               // Array of section objects with rows
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActionFlow {
  id                   String             @id @default(cuid())
  flowId               String
  flowCta              String
  flowMode             String             @default("published")
  flowData             Json?              // Additional flow parameters
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActionLocationRequest {
  id                   String             @id @default(cuid())
  requestText          String
  interactiveContentId String             @unique
  interactiveContent   InteractiveContent @relation(fields: [interactiveContentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// WhatsApp Official Template Support (replaces WhatsAppTemplate functionality)
model WhatsAppOfficialInfo {
  id           String   @id @default(cuid())
  templateId   String   // Meta's template ID
  status       String   // APPROVED, REJECTED, PENDING
  category     String   // UTILITY, MARKETING
  qualityScore String?
  components   Json     // Original Meta JSON for reference
  template     Template @relation(fields: [templateIdRel], references: [id], onDelete: Cascade)
  templateIdRel String  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templateId])
  @@index([status])
}

model LeadChatwit {
  id                     String  @id @default(cuid())
  sourceId               String  @unique // ID do lead no sistema externo (ex: número de telefone)
  name                   String?
  nomeReal               String? // Nome real do lead (editável)
  phoneNumber            String?
  email                  String? // Email do lead (editável)
  thumbnail              String? // URL da thumbnail
  concluido              Boolean @default(false)
  anotacoes              String? @db.Text
  pdfUnificado           String? // URL do PDF unificado
  imagensConvertidas     String? // Lista de URLs das imagens convertidas (JSON)
  leadUrl                String? // URL para abrir o chat no Chatwit
  fezRecurso             Boolean @default(false) // Indica se o lead fez recurso
  datasRecurso           String? // Lista de datas de recursos em formato JSON
  provaManuscrita        Json? // Texto da prova digitalizada
  manuscritoProcessado   Boolean @default(false) // Indica se o manuscrito foi processado
  aguardandoManuscrito   Boolean @default(false) // Indica se está aguardando processamento do manuscrito
  espelhoCorrecao        String? // Lista de URLs das imagens do espelho em formato JSON
  textoDOEspelho         Json? // Texto do espelho de correção processado
  espelhoProcessado      Boolean @default(false) // Indica se o espelho foi processado
  aguardandoEspelho      Boolean @default(false) // Indica se está aguardando processamento do espelho
  analiseUrl             String? // URL do PDF de análise da prova
  argumentacaoUrl        String? // URL do PDF de argumentação
  analiseProcessada      Boolean @default(false) // Indica se a análise foi processada
  aguardandoAnalise      Boolean @default(false) // Indica se está aguardando análise
  analisePreliminar      Json? // Dados da pré-análise
  analiseValidada        Boolean @default(false) // Indica se a análise foi validada pelo usuário
  consultoriaFase2       Boolean @default(false) // Indica se o lead está em modo consultoria fase 2
  recursoPreliminar      Json? // Dados do pré-recurso
  recursoValidado        Boolean @default(false) // Indica se o recurso foi validado pelo usuário
  recursoUrl             String? // URL do PDF do recurso validado
  recursoArgumentacaoUrl String? // URL do PDF de argumentação do recurso
  aguardandoRecurso      Boolean @default(false) // Indica se está aguardando processamento do recurso

  // Relacionamentos com WhatsApp removidos - não há necessidade de relacionamento direto
  seccional           String? // Seccional do exame (ex.: "OAB / MG")
  areaJuridica        String? // Área jurídica do exame
  notaFinal           Float? // Nota final obtida no exame
  situacao            String? // Situação final do exame (ex.: "APROVADO")
  inscricao           String? // Número de inscrição do exame
  examesParticipados  Json? // Lista de exames que o lead participou
  espelhoBibliotecaId String? // ID do espelho da biblioteca associado ao lead
  especialidade       EspecialidadeJuridica? // Especialidade jurídica do lead para uso do espelho padrão
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  // Relação com usuário
  usuarioId String
  usuario   UsuarioChatwit @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  // Relação com arquivos
  arquivos ArquivoLeadChatwit[]

  // Relação com espelho da biblioteca
  espelhoBiblioteca EspelhoBiblioteca? @relation(fields: [espelhoBibliotecaId], references: [id])

  @@index([usuarioId])
  @@index([sourceId])
  @@index([espelhoBibliotecaId])
  @@index([especialidade])
}

model ArquivoLeadChatwit {
  id            String   @id @default(cuid())
  fileType      String // "image" ou "pdf"
  dataUrl       String // URL do arquivo
  pdfConvertido String? // URL do PDF convertido (se for imagem)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relação com lead
  leadId String
  lead   LeadChatwit @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model WhatsAppConfig {
  id String @id @default(cuid())

  // --- CAMPOS ATUALIZADOS ---
  phoneNumberId String
  whatsappToken String @db.Text
  isActive      Boolean @default(true)
  whatsappBusinessAccountId String
  fbGraphApiBase String @default("https://graph.facebook.com/v22.0")

  usuarioChatwitId String
  usuarioChatwit   UsuarioChatwit @relation(fields: [usuarioChatwitId], references: [id], onDelete: Cascade)

  caixaEntradaId String?       @unique
  caixaEntrada   CaixaEntrada? @relation(name: "ConfigCaixa", fields: [caixaEntradaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([usuarioChatwitId, caixaEntradaId])
}

// Modelo para armazenar templates do WhatsApp
model WhatsAppTemplate {
  id         String @id @default(cuid())
  /// ID retornado pela API do WhatsApp (único na plataforma)
  templateId String

  /// Nome do template
  name String

  /// Status do template (APPROVED, REJECTED, PENDING, etc.)
  status String

  /// Categoria (ex.: UTILITY, MARKETING, AUTHENTICATION, etc.)
  category String

  /// Subcategoria, se aplicável (ex.: ORDER_DETAILS, ORDER_STATUS, etc.)
  subCategory String?

  /// Idioma do template (ex.: pt_BR, en_US)
  language String

  /// JSON com os componentes do template (HEADER, BODY, FOOTER, BUTTONS) e exemplos
  components Json

  /// Qualidade do template (ex.: GREEN, YELLOW, RED, UNKNOWN)
  qualityScore String?

  /// Categoria correta determinada pelo sistema (se houver)
  correctCategory String?

  /// Indica se o rastreamento de links foi desativado no nível do template
  ctaUrlLinkTrackingOptedOut Boolean?

  /// Se o template foi criado a partir de uma biblioteca, guarda o nome original
  libraryTemplateName String?

  /// TTL para envio da mensagem (em segundos)
  messageSendTtlSeconds Int?

  /// Formato dos parâmetros (NAMED ou POSITIONAL)
  parameterFormat String?

  /// Categoria anterior do template, se houver (útil para histórico de edições)
  previousCategory String?

  /// Flag para marcar o template como favorito (ex.: para acesso rápido)
  isFavorite Boolean @default(false)

  /// Data da última edição (útil para controle de versão)
  lastEdited DateTime?

  /// Histórico de edições em formato JSON (ex.: [{ editedAt: Date, changes: {...} }, ...])
  editHistory Json?

  /// URL pública da mídia no MinIO (para vídeos, imagens, etc.)
  publicMediaUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relação principal, sempre presente
  usuarioChatwitId String
  usuarioChatwit   UsuarioChatwit @relation(fields: [usuarioChatwitId], references: [id], onDelete: Cascade)

  // NOVA RELAÇÃO: Opcional, para templates específicos de uma caixa
  caixaEntradaId String?
  caixaEntrada   CaixaEntrada?        @relation(fields: [caixaEntradaId], references: [id], onDelete: SetNull)
  // Relação com mapeamentos de intenção
  mapeamentos    MapeamentoIntencao[]

  @@index([usuarioChatwitId])
  @@index([caixaEntradaId])
  @@unique([templateId, usuarioChatwitId])
  @@unique([templateId])
}

// Modelos para o ChatwitIA - armazenamento de chats de IA
model ChatSession {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String           @default("Nova conversa")
  model           String           @default("chatgpt-4o-latest")
  summary         String? // Resumo gerado automaticamente da conversa
  lastResponseId  String? // ID da última resposta da OpenAI para multi-turn
  messages        ChatMessage[]
  files           ChatFile[] // Relação com arquivos
  generatedImages GeneratedImage[] // Relação com imagens geradas
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@index([lastResponseId]) // Índice para busca rápida por responseId
}

model ChatMessage {
  id                 String      @id @default(cuid())
  sessionId          String
  session            ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role               String // "system", "user", "assistant"
  content            String      @db.Text
  contentType        String      @default("text") // "text", "audio", "image"
  audioData          String?     @db.Text // Base64 de audio, se aplicável
  imageUrl           String? // URL da imagem, se aplicável
  previousResponseId String? // ID da resposta anterior para multi-turn conversations
  responseId         String? // ID desta resposta da OpenAI para referência futura

  // Novos campos para dados da Responses API
  modelUsed         String? // Modelo usado na resposta (ex: "gpt-4.1-2025-04-14")
  inputTokens       Int? // Tokens de entrada
  outputTokens      Int? // Tokens de saída
  totalTokens       Int? // Total de tokens
  reasoningTokens   Int? // Tokens de reasoning (para modelos o-series)
  temperature       Float? // Temperatura usada
  topP              Float? // Top-p usado
  responseStatus    String? // Status da resposta ("completed", "failed", etc.)
  responseCreatedAt DateTime? // Timestamp da criação da resposta na OpenAI

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([responseId])
}

// Modelo para armazenar arquivos associados a sessões de chat
model ChatFile {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  /**
   * NOVOS CAMPOS ----------------------------------------------
   */
  storageUrl    String // URL assinado ou público no MinIO
  openaiFileId  String? // ID retornado pela OpenAI (nulo enquanto não houver sync)
  status        String  @default("stored") // stored | syncing | synced | failed
  purpose       String? // user_data | vision | assistants …
  thumbnail_url String? // URL da thumbnail no MinIO (opcional)
  /**
   * -----------------------------------------------------------
   */

  filename  String
  fileType  String
  createdAt DateTime  @default(now())
  syncedAt  DateTime? // Quando o arquivo foi aceito pela OpenAI

  @@index([sessionId])
  @@index([openaiFileId])
}

// Modelo para armazenar imagens geradas por IA
model GeneratedImage {
  id                 String   @id @default(cuid())
  userId             String
  sessionId          String?
  prompt             String
  revisedPrompt      String?
  model              String
  imageUrl           String
  thumbnailUrl       String?
  mimeType           String   @default("image/png")
  size               String?
  quality            String?
  previousResponseId String? // ID da resposta anterior usada para gerar esta imagem (multi-turn)
  responseId         String? // ID desta resposta da OpenAI para referência futura (multi-turn)

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  session ChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
  @@index([responseId]) // Índice para busca rápida por responseId
  @@index([previousResponseId]) // Índice para busca por cadeia de refinamentos
}

// Button reaction mapping model for Dialogflow async response system
model ButtonReactionMapping {
  id          String   @id @default(cuid())
  buttonId    String   @unique
  emoji       String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([buttonId])
  @@index([isActive])
}

// Modelo para Biblioteca de Espelhos
model EspelhoBiblioteca {
  id                          String   @id @default(cuid())
  nome                        String // Nome identificador do espelho
  descricao                   String? // Descrição opcional do espelho
  textoDOEspelho              Json? // Texto do espelho de correção
  espelhoCorrecao             String? // Lista de URLs das imagens do espelho em formato JSON
  isAtivo                     Boolean  @default(true) // Se o espelho está ativo na biblioteca
  totalUsos                   Int      @default(0) // Contador de quantas vezes foi usado
  espelhoBibliotecaProcessado Boolean  @default(false) // Indica se o espelho da biblioteca foi processado
  aguardandoEspelho           Boolean  @default(false) // Indica se está aguardando processamento do espelho
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  // Relação com usuário que criou o espelho
  criadoPorId String
  criadoPor   UsuarioChatwit @relation(fields: [criadoPorId], references: [id], onDelete: Cascade)

  // Relação com leads que usam este espelho
  leads LeadChatwit[]

  @@index([criadoPorId])
  @@index([isAtivo])
  @@index([nome])
}

// Modelo para Espelhos Padrão (templates globais por especialidade)
model EspelhoPadrao {
  id                      String                @id @default(cuid())
  especialidade           EspecialidadeJuridica @unique // Especialidade jurídica única
  nome                    String // Nome do espelho padrão (ex: "Padrão de respostas definitivo (Direito Civil)")
  descricao               String? // Descrição opcional
  textoMarkdown           String?               @db.Text // Texto do espelho em formato Markdown
  espelhoCorrecao         String? // Lista de URLs das imagens do espelho em formato JSON
  isAtivo                 Boolean               @default(true) // Se o espelho está ativo
  totalUsos               Int                   @default(0) // Contador de quantas vezes foi usado
  processado              Boolean               @default(false) // Indica se o espelho foi processado pelo sistema externo
  aguardandoProcessamento Boolean               @default(false) // Indica se está aguardando processamento
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  // Relação com usuário que criou/atualizou por último
  atualizadoPorId String
  atualizadoPor   UsuarioChatwit @relation(fields: [atualizadoPorId], references: [id], onDelete: Cascade)

  @@index([especialidade])
  @@index([isAtivo])
}

// Modelo para configuração do MTF Diamante
model MtfDiamanteConfig {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Configurações específicas do sistema
  isActive Boolean @default(true)

  // Relacionamento com as variáveis personalizadas (NOVO)
  variaveis MtfDiamanteVariavel[]

  // Relacionamentos existentes
  lotes          MtfDiamanteLote[]
  intentMappings MtfDiamanteIntentMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
}

// Novo modelo para variáveis dinâmicas do MTF Diamante
model MtfDiamanteVariavel {
  id    String @id @default(cuid())
  chave String // Ex: "chave_pix", "nome_escritorio"
  valor String @db.Text // Ex: "email@dominio.com", "Meu Escritório"

  // Relacionamento com a configuração principal
  configId String
  config   MtfDiamanteConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([configId, chave]) // Garante que cada chave seja única por configuração
  @@index([configId])

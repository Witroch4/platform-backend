// Modelo para lotes do MTF Diamante
model MtfDiamanteLote {
  id       String            @id @default(cuid())
  configId String
  config   MtfDiamanteConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  // Informações do lote
  numero Int // Número do lote (1, 2, 3...)
  nome   String // Nome do lote (ex: "Primeiro Lote", "Lote Premium")
  valor  String // Valor do lote (ex: "R$ 287,90")

  // Datas
  dataInicio DateTime
  dataFim    DateTime

  // Status
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([configId])
  @@index([numero])

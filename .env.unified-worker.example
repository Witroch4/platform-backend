# .env.unified-worker.example
# Configurações específicas para o worker unificado

# ============================================================================
# WORKER CONFIGURATION
# ============================================================================

# Tipo do worker (sempre "unified" para o novo sistema)
WORKER_TYPE=unified
WORKER_NAME=socialwise-unified-worker

# ============================================================================
# CONCURRENCY & PERFORMANCE
# ============================================================================

# Concorrência do worker de leads Chatwit
LEADS_CHATWIT_CONCURRENCY=5
LEADS_CHATWIT_LOCK_DURATION=60000

# Processamento direto de webhooks (recomendado: true)
WEBHOOK_DIRECT_PROCESSING=true

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

# URL do Redis (obrigatório)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USE_TLS=false

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# URL do PostgreSQL (obrigatório)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/socialWise?schema=public

# ============================================================================
# AI INTEGRATION
# ============================================================================

# OpenAI API Key (obrigatório para AI workers)
OPENAI_API_KEY=sk-your-key-here

# Google Gemini API Key (opcional, habilita modelos Gemini 3)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# Anthropic API Key (opcional)
ANTHROPIC_API_KEY=your-anthropic-key-here

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# Chatwit Access Token
CHATWITACESSTOKEN=your-chatwit-token
CHATWIT_BASE_URL=https://api.chatwit.com

# S3/MinIO Configuration
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=your-bucket
S3Host=your-s3-host
S3_ENDPOINT=https://your-s3-endpoint

# ILovePDF
ILOVEPDF_PUBLIC_KEY=your-public-key
ILOVEPDF_SECRET_KEY=your-secret-key

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Ambiente (development/production)
NODE_ENV=development

# Desabilitar telemetria do Next.js
NEXT_TELEMETRY_DISABLED=1

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# Nível de log (debug, info, warn, error)
LOG_LEVEL=info

# Diretório para logs (opcional)
LOG_DIR=/app/logs

# ============================================================================
# DOCKER SETTINGS (para produção)
# ============================================================================

# Usuário Docker
DOCKER_USER=witrocha

# Tag da imagem
DOCKER_TAG=latest

# Registry
DOCKER_REGISTRY=docker.io

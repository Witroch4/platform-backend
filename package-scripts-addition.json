{
	"scripts": {
		"test:comprehensive": "node scripts/run-tests.js",
		"test:pre-check": "node scripts/pre-test-check.js",
		"test:unit": "jest __tests__/unit --config=jest.config.sistema-refatoracao.js",
		"test:integration": "jest __tests__/integration --config=jest.config.sistema-refatoracao.js --testTimeout=60000",
		"test:performance": "jest __tests__/performance --config=jest.config.sistema-refatoracao.js --testTimeout=120000",
		"test:e2e": "jest __tests__/e2e --config=jest.config.sistema-refatoracao.js --testTimeout=180000",
		"test:frontend": "jest __tests__/frontend --config=jest.config.sistema-refatoracao.js",
		"test:watch": "jest --watch --config=jest.config.sistema-refatoracao.js",
		"test:coverage": "jest --coverage --config=jest.config.sistema-refatoracao.js",
		"test:debug": "jest --detectOpenHandles --forceExit --config=jest.config.sistema-refatoracao.js"
	}
}

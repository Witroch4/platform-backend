# Configurações específicas para Docker/Produção
# Copie para .env.production e ajuste os valores

# Database Pool Configuration
DATABASE_CONNECTION_LIMIT=10
DATABASE_POOL_TIMEOUT=10000
DATABASE_QUERY_TIMEOUT=30000
DEBUG=1
# Redis Configuration
REDIS_MAX_RETRIES=3
REDIS_CONNECT_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=5000
REDIS_KEEPALIVE=30000
DEBUG_MIRROR_GROUPS=1
# Application Configuration
NODE_ENV=production  # ou "staging" para ambiente de teste
LOG_LEVEL=error

# Health Check Configuration
HEALTH_CHECK_TIMEOUT=5000

# Worker Configuration (Leads Chatwit)
LEADS_CHATWIT_CONCURRENCY=3        # Número de jobs simultâneos (default: 3)
LEADS_CHATWIT_LOCK_DURATION=60000  # Timeout dos jobs em ms (default: 60s)

# Webhook Processing Mode
WEBHOOK_DIRECT_PROCESSING=true     # true=direto, false=via fila BullMQ
HEALTH_CHECK_INTERVAL=30000

# Container Resource Limits (informativo)
# Configure no docker-compose.yml ou Kubernetes
CONTAINER_MEMORY_LIMIT=1024M
CONTAINER_CPU_LIMIT=1.0

# SocialWise Flow Concurrency Configuration
SOCIALWISE_CONCURRENCY_LIMIT=100              # Operações simultâneas por inbox (default: 100)
SOCIALWISE_GLOBAL_CONCURRENCY_LIMIT=300       # Limite global de operações (default: 300)
SOCIALWISE_QUEUE_TIMEOUT_MS=5000              # Timeout da fila em ms (default: 5000)
SOCIALWISE_DEGRADATION_ENABLED=true           # Habilita degradação em sobrecarga (default: true)

# LangGraph ReactAgent Configuration
# Controla se o agente ReAct é executado no band ROUTER (score <0.50)
# false (default): Pula o ReactAgent, vai direto para RouterLLM (mais rápido, menos custo)
# true: Executa ReactAgent com tools (get_datetime, RAG) antes do RouterLLM
LANGGRAPH_REACT=false

# SocialWise Flow Message Debounce Configuration
# Quando um usuário envia múltiplas mensagens em sequência rápida,
# o sistema aguarda SOCIALWISE_DEBOUNCE_MS antes de processar, agregando todas as mensagens.
# Benefícios: menos chamadas de API, contexto completo, evita race conditions de sessão.
# 5000 (default): Aguarda 5 segundos de inatividade antes de processar
# 0: Desabilita o debounce (processa cada mensagem imediatamente)
SOCIALWISE_DEBOUNCE_MS=5000

# Monitoring Logs Configuration
# Controla logs verbosos de monitoramento (heartbeats, queue metrics, resource usage)
# false (default): Desabilita logs de monitoramento para manter console limpo
# true: Habilita logs detalhados de monitoramento para debug
MONITOR_LOG=false

# Conversation History Strategy Configuration
# Controla como o histórico de conversa é gerenciado entre turnos de mensagem.
#
# "manual" (default): Histórico salvo no Redis e reconstruído manualmente em cada chamada.
#   - Vantagens: Funciona com QUALQUER LLM (OpenAI, Gemini, Claude, Groq, etc.)
#   - Desvantagens: Mais tokens enviados a cada turno (histórico completo)
#   - Recomendado: Para multi-provider ou quando precisa de controle total do histórico
#
# "openai_native": Usa previous_response_id da OpenAI Responses API.
#   - Vantagens: OpenAI gerencia contexto internamente, menos tokens enviados
#   - Desvantagens: SOMENTE funciona com OpenAI Responses API
#   - Recomendado: Para uso exclusivo com OpenAI e otimização de tokens/custo
#
CONVERSATION_HISTORY_STRATEGY=manual
# Configurações específicas para Docker/Produção
# Copie para .env.production e ajuste os valores

# Database Pool Configuration
DATABASE_CONNECTION_LIMIT=10
DATABASE_POOL_TIMEOUT=10000
DATABASE_QUERY_TIMEOUT=30000
DEBUG=1
# Redis Configuration
REDIS_MAX_RETRIES=3
REDIS_CONNECT_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=5000
REDIS_KEEPALIVE=30000

# Application Configuration
NODE_ENV=production  # ou "staging" para ambiente de teste
LOG_LEVEL=error

# Health Check Configuration
HEALTH_CHECK_TIMEOUT=5000

# Worker Configuration (Leads Chatwit)
LEADS_CHATWIT_CONCURRENCY=3        # Número de jobs simultâneos (default: 3)
LEADS_CHATWIT_LOCK_DURATION=60000  # Timeout dos jobs em ms (default: 60s)

# Webhook Processing Mode
WEBHOOK_DIRECT_PROCESSING=true     # true=direto, false=via fila BullMQ
HEALTH_CHECK_INTERVAL=30000

# Container Resource Limits (informativo)
# Configure no docker-compose.yml ou Kubernetes
CONTAINER_MEMORY_LIMIT=1024M
CONTAINER_CPU_LIMIT=1.0